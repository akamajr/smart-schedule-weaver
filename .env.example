# ============================================================
# .env.example — smart-schedule-weaver
# Copy this file to .env and fill in your values
# ============================================================

# Public keys (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-key>"
NEXT_PUBLIC_SUPABASE_PROJECT_ID="<your-project-ref>"

# Auth redirect URLs
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_AUTH_REDIRECT_URL="http://localhost:3000/auth/callback"

# App configuration
NEXT_PUBLIC_APP_NAME="Smart Schedule Weaver"

# ============================================================
# SERVER-SIDE ONLY — Never expose to the browser!
# ============================================================
# Service role key (bypasses RLS - admin operations only)
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# Database direct connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.<your-project-ref>.supabase.co:5432/postgres"

# Admin Signup Code (Server-side validation only)
ADMIN_INVITE_CODE="<your-secret-invite-code>"
